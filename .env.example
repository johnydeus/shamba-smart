# ── PUBLIC KEYS (safe to commit, ship in APK) ────────────────────────────────
# These stay in the app — Supabase RLS enforces access control.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── SECRET KEYS (do NOT put here — store in Supabase Edge Function secrets) ──
# Run these commands once (after `supabase login`):
#
#   supabase secrets set CLAUDE_API_KEY=sk-ant-...        --project-ref your-ref
#   supabase secrets set ISDASOIL_TOKEN=eyJ...             --project-ref your-ref
#   supabase secrets set CROP_HEALTH_KEY=your_key_here    --project-ref your-ref
#   supabase secrets set PLANT_ID_KEY=your_key_here       --project-ref your-ref
#   supabase secrets set EOSDA_API_KEY=your_key_here      --project-ref your-ref
#   supabase secrets set PLANET_API_KEY=your_key_here     --project-ref your-ref
#
# Keys that need ROTATING (they were exposed in a previous session):
#   - CLAUDE_API_KEY   → revoke at console.anthropic.com and reissue
#   - ISDASOIL_TOKEN   → refresh at app.isda-africa.com
#   - CROP_HEALTH_KEY  → rotate at crop.kindwise.com
#   - PLANT_ID_KEY     → rotate at web.plant.id
